<Page x:Class="SosPOS.Views.PosView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Punto de Venta"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- Panel de productos -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,16,0" Padding="20">
            <StackPanel>
                <TextBlock Text="Productos" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                <TextBox x:Name="TxtBuscar" Style="{StaticResource BaseTextBox}"
                         Text="" Tag="Buscar producto..."
                         Margin="0,0,0,16" TextChanged="TxtBuscar_TextChanged"/>
                <ListView x:Name="ListaProductos" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Codigo" Width="80" DisplayMemberBinding="{Binding Codigo}"/>
                            <GridViewColumn Header="Nombre" Width="200" DisplayMemberBinding="{Binding Nombre}"/>
                            <GridViewColumn Header="Precio" Width="100" DisplayMemberBinding="{Binding PrecioFormateado}"/>
                            <GridViewColumn Header="Stock" Width="60" DisplayMemberBinding="{Binding Stock}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <!-- Panel de carrito -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock Text="Venta Actual" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                <ListView x:Name="ListaCarrito" BorderThickness="0" Height="300">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Producto" Width="150" DisplayMemberBinding="{Binding Nombre}"/>
                            <GridViewColumn Header="Cant." Width="50" DisplayMemberBinding="{Binding Cantidad}"/>
                            <GridViewColumn Header="Total" Width="80" DisplayMemberBinding="{Binding TotalFormateado}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Separator Margin="0,16"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <TextBlock Text="TOTAL: " FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="TxtTotal" Text="$0.00" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                <Button Content="Cobrar" Style="{StaticResource PrimaryButton}"
                        Click="BtnCobrar_Click" Margin="0,8,0,0"/>
                <Button Content="Cancelar Venta"
                        Background="#95A5A6" Foreground="White"
                        Padding="20,10" BorderThickness="0" Cursor="Hand"
                        Click="BtnCancelar_Click" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
