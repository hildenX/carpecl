<Page x:Class="SosPOS.Views.InventarioView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Inventario"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Inventario" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="+ Nuevo Producto" Style="{StaticResource PrimaryButton}"
                    Click="BtnNuevo_Click"/>
            <TextBox x:Name="TxtBuscar" Style="{StaticResource BaseTextBox}"
                     Width="250" Margin="16,0,0,0"
                     TextChanged="TxtBuscar_TextChanged"/>
        </StackPanel>

        <!-- Tabla de productos -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16">
            <ListView x:Name="ListaProductos" BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Codigo" Width="80" DisplayMemberBinding="{Binding Codigo}"/>
                        <GridViewColumn Header="Nombre" Width="220" DisplayMemberBinding="{Binding Nombre}"/>
                        <GridViewColumn Header="Categoria" Width="120" DisplayMemberBinding="{Binding Categoria}"/>
                        <GridViewColumn Header="Precio" Width="100" DisplayMemberBinding="{Binding PrecioFormateado}"/>
                        <GridViewColumn Header="Stock" Width="70" DisplayMemberBinding="{Binding Stock}"/>
                        <GridViewColumn Header="Acciones" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Editar" Margin="0,0,8,0"
                                                Click="BtnEditar_Click" Tag="{Binding}"/>
                                        <Button Content="Eliminar" Foreground="Red"
                                                Click="BtnEliminar_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</Page>
