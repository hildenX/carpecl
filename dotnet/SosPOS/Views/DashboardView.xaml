<Window x:Class="SosPOS.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SOS POS - Dashboard"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Margin="0,30,0,0">
                <TextBlock Text="SOS POS"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button Content="Inicio" Tag="Home"
                        Style="{StaticResource NavButton}"
                        Click="NavButton_Click"/>
                <Button Content="Punto de Venta" Tag="POS"
                        Style="{StaticResource NavButton}"
                        Click="NavButton_Click"/>
                <Button Content="Inventario" Tag="Inventario"
                        Style="{StaticResource NavButton}"
                        Click="NavButton_Click"/>

                <!-- Spacer -->
                <StackPanel VerticalAlignment="Bottom" Margin="20,300,20,20">
                    <Button Content="Cerrar Sesion"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Contenido principal -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
